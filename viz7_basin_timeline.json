{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "The BOD Rollercoaster: 22 Years of Basin Quality",
  "description": "Percentage of basins classified as clean vs polluted by BOD, 2000-2021",
  "width": 600,
  "height": 350,
  "data": {
    "url": "basin_bod_timeline_long.csv"
  },
  "transform": [
    {
      "calculate": "datum.status == 'Clean' ? 1 : 2",
      "as": "order"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": true,
        "point": true,
        "tooltip": true,
        "opacity": 0.7
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "title": "Year",
          "scale": {
            "domain": [
              2000,
              2021
            ],
            "nice": false
          }
        },
        "y": {
          "field": "percentage",
          "type": "quantitative",
          "title": "% of Basins",
          "scale": {
            "domain": [
              0,
              100
            ]
          },
          "stack": "zero"
        },
        "color": {
          "field": "status",
          "type": "nominal",
          "scale": {
            "domain": [
              "Clean",
              "Polluted"
            ],
            "range": [
              "#27ae60",
              "#3c75e7"
            ]
          },
          "title": "Status"
        },
        "order": {
          "field": "order"
        },
        "tooltip": [
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year"
          },
          {
            "field": "status",
            "type": "nominal"
          },
          {
            "field": "percentage",
            "type": "quantitative",
            "format": ".1f",
            "title": "%"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#7f8c8d",
        "strokeWidth": 2,
        "strokeDash": [
          8,
          4
        ]
      },
      "encoding": {
        "x": {
          "datum": 2013
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "text": "2013: Crisis Peak",
        "color": "#3c75e7",
        "fontSize": 12,
        "fontWeight": "bold",
        "align": "left",
        "dx": 5
      },
      "encoding": {
        "x": {
          "datum": 2013
        },
        "y": {
          "datum": 95
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "text": "2021: Recovery",
        "color": "#27ae60",
        "fontSize": 12,
        "fontWeight": "bold",
        "align": "right",
        "dx": -5
      },
      "encoding": {
        "x": {
          "datum": 2021
        },
        "y": {
          "datum": 95
        }
      }
    }
  ]
}